# PostgreSQL пароль (обязательно измените для production!)
POSTGRES_PASSWORD=change_me_to_secure_random_string

# API Secret для генерации токенов (обязательно измените!)
API_SECRET=generate_with_openssl_rand_hex_32

# Интервал опроса серверов в секундах
COLLECTOR_INTERVAL=60

# Домен для API (localhost для разработки)
DOMAIN=localhost

# Email для уведомлений Let's Encrypt
EMAIL=admin@example.com
