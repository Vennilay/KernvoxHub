# PostgreSQL пароль (обязательно измените для production!)
POSTGRES_PASSWORD=change_me_to_secure_random_string

# API Secret для генерации токенов (обязательно измените!)
API_SECRET=generate_with_openssl_rand_hex_32

# Ключ шифрования для паролей и SSH-ключей (Fernet, base64)
# Сгенерировать: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=ваш_fernet_ключ_base64

# Redis пароль (используется для rate limiting и кэширования токенов)
REDIS_PASSWORD=change_me_to_secure_redis_password

# INTERNAL_API_KEY — ключ для записи метрик (POST /metrics).
# Оставьте пустым для разработки. В production сгенерируйте: openssl rand -hex 32
INTERNAL_API_KEY=

# CORS origins — через запятую. Используйте "*" только для разработки.
# Пример: https://app.example.com,https://admin.example.com
CORS_ORIGINS=*

# Интервал опроса серверов в секундах
COLLECTOR_INTERVAL=60

# Домен для API (localhost для разработки)
DOMAIN=localhost

# Email для уведомлений Let's Encrypt
EMAIL=admin@example.com
