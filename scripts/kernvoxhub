#!/bin/bash

set -Eeuo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

installation_state_file_path() {
    if [ -n "${KERNVOX_STATE_FILE:-}" ]; then
        printf '%s' "$KERNVOX_STATE_FILE"
        return 0
    fi

    [ -n "${HOME:-}" ] || return 1
    printf '%s/%s/install-dir' "${XDG_CONFIG_HOME:-${HOME}/.config}" "kernvoxhub"
}

normalize_directory_path() {
    local dir="$1"

    [ -n "$dir" ] || return 1
    (
        cd "$dir" 2>/dev/null && pwd -P
    )
}

is_installation_root() {
    local dir="$1"

    [ -n "$dir" ] || return 1
    [ -f "${dir}/update.sh" ] || return 1
    [ -f "${dir}/docker-compose.yml" ] || return 1
    [ -d "${dir}/scripts" ] || return 1
}

candidate_root_from_mount_source() {
    local source="$1"

    case "$source" in
        */scripts/init_db.sql)
            normalize_directory_path "$(dirname "$(dirname "$source")")"
            ;;
        */certbot/www)
            normalize_directory_path "$(dirname "$(dirname "$source")")"
            ;;
        */nginx)
            normalize_directory_path "$(dirname "$source")"
            ;;
        *)
            return 1
            ;;
    esac
}

load_root_from_state_file() {
    local state_file=""
    local install_root=""

    state_file="$(installation_state_file_path)" || return 1
    [ -f "$state_file" ] || return 1
    IFS= read -r install_root < "$state_file" || return 1

    normalize_directory_path "$install_root"
}

detect_root_from_containers() {
    local container_name=""
    local mount_source=""
    local candidate_root=""

    for container_name in kernvox-nginx kernvox-postgres; do
        while IFS= read -r mount_source; do
            [ -n "$mount_source" ] || continue

            candidate_root="$(candidate_root_from_mount_source "$mount_source" 2>/dev/null || true)"
            if is_installation_root "$candidate_root"; then
                printf '%s' "$candidate_root"
                return 0
            fi
        done < <(docker inspect --format '{{range .Mounts}}{{println .Source}}{{end}}' "$container_name" 2>/dev/null || true)
    done

    return 1
}

resolve_installation_root() {
    local install_root=""

    if [ -n "${KERNVOX_INSTALL_DIR:-}" ]; then
        install_root="$(normalize_directory_path "$KERNVOX_INSTALL_DIR" 2>/dev/null || true)"
        is_installation_root "$install_root" || {
            echo "KERNVOX_INSTALL_DIR не указывает на каталог установленного KernvoxHub." >&2
            return 1
        }

        printf '%s' "$install_root"
        return 0
    fi

    install_root="$(load_root_from_state_file 2>/dev/null || true)"
    if is_installation_root "$install_root"; then
        printf '%s' "$install_root"
        return 0
    fi

    install_root="$(detect_root_from_containers 2>/dev/null || true)"
    if is_installation_root "$install_root"; then
        printf '%s' "$install_root"
        return 0
    fi

    return 1
}

usage() {
    cat <<'EOF'
KernvoxHub CLI

Usage:
  kernvoxhub              Show installation status, check updates, and offer update.
  kernvoxhub help         Show this help.
  kernvoxhub status       Show Docker Compose service status.
  kernvoxhub check-update Check whether a new version is available.
  kernvoxhub update       Install the latest available version.
  kernvoxhub logs [svc]   Show docker compose logs (-f), optionally for one service.
  kernvoxhub add-server   Run interactive server onboarding inside backend.
  kernvoxhub list-servers List configured servers.
  kernvoxhub test-server <id>
  kernvoxhub reboot-server <id> [--yes]
  kernvoxhub metrics <id>
EOF
}

compose_exec() {
    if docker compose version >/dev/null 2>&1; then
        docker compose "$@"
    elif command -v docker-compose >/dev/null 2>&1; then
        docker-compose "$@"
    else
        return 1
    fi
}

print_header() {
    echo "========================================"
    echo "  KernvoxHub CLI"
    echo "========================================"
}

show_status() {
    local install_root="$1"

    echo "📁 Установка: ${install_root}"

    echo ""
    echo "📊 Сервисы:"
    (
        cd "$install_root"
        compose_exec ps
    ) || echo "  Docker Compose недоступен или сервисы ещё не запускались."
}

update_upstream_ref() {
    local install_root="$1"
    local ref=""

    ref="$(git -C "$install_root" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)"
    if [ -n "$ref" ]; then
        printf '%s' "$ref"
        return 0
    fi

    ref="$(git -C "$install_root" symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null || true)"
    if [ -n "$ref" ]; then
        printf '%s' "$ref"
        return 0
    fi

    if git -C "$install_root" rev-parse --verify origin/main >/dev/null 2>&1; then
        printf '%s' "origin/main"
        return 0
    fi

    return 1
}

check_update_state() {
    local install_root="$1"
    local upstream_ref=""
    local pending_count=""

    if ! command -v git >/dev/null 2>&1 || [ ! -d "${install_root}/.git" ]; then
        printf '%s' "unknown"
        return 0
    fi

    git -C "$install_root" fetch --quiet --prune origin >/dev/null 2>&1 || {
        printf '%s' "unknown"
        return 0
    }

    upstream_ref="$(update_upstream_ref "$install_root" 2>/dev/null || true)"
    if [ -z "$upstream_ref" ]; then
        printf '%s' "unknown"
        return 0
    fi

    pending_count="$(git -C "$install_root" rev-list --count "HEAD..${upstream_ref}" 2>/dev/null || echo 0)"
    if [ "$pending_count" -gt 0 ]; then
        printf '%s' "available"
        return 0
    fi

    printf '%s' "current"
}

print_update_status() {
    local install_root="$1"
    local state=""

    state="$(check_update_state "$install_root")"
    case "$state" in
        available)
            echo "🔔 Доступна новая версия."
            ;;
        current)
            echo "✅ Установлена актуальная версия."
            ;;
        *)
            echo "⚠️  Не удалось проверить обновления. Проверьте интернет или remote origin."
            ;;
    esac
}

run_update() {
    local install_root="$1"
    shift

    export KERNVOX_INSTALL_DIR="$install_root"
    exec "${install_root}/update.sh" "$@"
}

run_logs() {
    local install_root="$1"
    shift

    cd "$install_root"
    compose_exec logs -f "$@" || {
        echo "Docker Compose не найден." >&2
        exit 1
    }
}

run_backend_cli() {
    local install_root="$1"
    shift

    cd "$install_root"
    compose_exec exec backend python -m cli.main "$@" || {
        echo "Не удалось выполнить backend CLI. Проверьте, что сервис backend запущен." >&2
        exit 1
    }
}

interactive_menu() {
    local install_root="$1"
    local answer=""
    local update_state=""

    echo ""
    update_state="$(check_update_state "$install_root")"
    case "$update_state" in
        available)
            echo "🔔 Доступна новая версия."
            ;;
        current)
            echo "✅ Установлена актуальная версия."
            ;;
        *)
            echo "⚠️  Не удалось проверить обновления автоматически."
            ;;
    esac
    echo ""
    echo "Команды:"
    echo "  kernvoxhub check-update"
    echo "  kernvoxhub update"
    echo "  kernvoxhub status"
    echo "  kernvoxhub logs [service]"
    echo ""

    if [ "$update_state" = "available" ]; then
        read -r -p "Установить новую версию сейчас? [Y/n]: " answer || answer="y"
        case "${answer:-y}" in
            y|Y|yes|YES)
                run_update "$install_root"
                ;;
            *)
                echo "Обновление не запускалось."
                ;;
        esac
    fi
}

main() {
    local install_root=""
    local command="${1:-}"

    case "$command" in
        help|-h|--help)
            usage
            exit 0
            ;;
    esac

    install_root="$(resolve_installation_root)" || {
        echo "Не удалось определить каталог установки KernvoxHub. Запустите setup.sh в каталоге проекта или задайте KERNVOX_INSTALL_DIR=/path/to/KernvoxHub." >&2
        exit 1
    }

    export KERNVOX_INSTALL_DIR="$install_root"

    case "$command" in
        "" )
            print_header
            echo ""
            show_status "$install_root"
            interactive_menu "$install_root"
            ;;
        status)
            show_status "$install_root"
            echo ""
            print_update_status "$install_root"
            ;;
        check-update)
            print_update_status "$install_root"
            ;;
        update)
            shift
            run_update "$install_root" "$@"
            ;;
        logs)
            shift
            run_logs "$install_root" "$@"
            ;;
        add-server)
            shift
            run_backend_cli "$install_root" add-server "$@"
            ;;
        list-servers)
            shift
            run_backend_cli "$install_root" list-servers "$@"
            ;;
        test-server)
            shift
            run_backend_cli "$install_root" test-server "$@"
            ;;
        reboot-server)
            shift
            run_backend_cli "$install_root" reboot-server "$@"
            ;;
        metrics)
            shift
            run_backend_cli "$install_root" metrics "$@"
            ;;
        *)
            echo "Неизвестная команда: ${command}" >&2
            echo "" >&2
            usage >&2
            exit 1
            ;;
    esac
}

main "$@"
